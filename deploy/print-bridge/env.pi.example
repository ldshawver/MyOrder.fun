PORT=3100
BIND_HOST=0.0.0.0

# Must match PRINT_BRIDGE_API_KEY in deploy/.env on the VPS.
PRINT_BRIDGE_API_KEY=replace-with-the-vps-print-bridge-api-key

# Raspberry Pi receipt queue.
PRINTER_NAME=receipt
CUPS_RAW=true

# Optional fallback if CUPS is unavailable and the USB device exists.
# USB_DEVICE=/dev/usb/lp0

# Optional direct ethernet thermal printer fallback.
# DIRECT_PRINTER_IP=
# DIRECT_PRINTER_PORT=9100
# DIRECT_TIMEOUT_MS=3000

MAX_COPIES=5
MAX_BODY_BYTES=2097152
