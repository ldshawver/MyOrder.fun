PORT=3001
PRINT_BRIDGE_API_KEY=paste_a_long_random_secret_here

# ── Method 1: Direct raw socket to printer (fastest) ────────────────────────
# IP address of the thermal printer on your local network
# The bridge will try this first before falling back to CUPS or USB
DIRECT_PRINTER_IP=192.168.68.66
DIRECT_PRINTER_PORT=9100
DIRECT_TIMEOUT_MS=3000

# ── Method 2: CUPS printer name ──────────────────────────────────────────────
# Run: lpstat -p   to list available printers on this machine
PRINTER_NAME=PL70e

# ── Method 3: Raw USB device (Linux only) ───────────────────────────────────
USB_DEVICE=
