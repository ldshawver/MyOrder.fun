# ═══════════════════════════════════════════════════════════
#  Alavont — Self-Hosting Environment Variables
#  Copy this file to .env (in the repo root) and fill in every value.
#  NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# IMPORTANT: Docker Compose uses the "db" service name as the hostname.
# Use @db:5432 (NOT localhost) when running via docker compose.
DATABASE_URL=postgresql://alavont:CHANGE_ME_DB_PASSWORD@db:5432/alavont

# Internal postgres credentials (must match DATABASE_URL above)
POSTGRES_DB=alavont
POSTGRES_USER=alavont
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Clerk Authentication ────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=paste_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=paste_your_clerk_publishable_key_here
VITE_CLERK_PUBLISHABLE_KEY=paste_your_clerk_publishable_key_here
# Clerk Webhooks → Signing Secret (from Clerk Dashboard → Webhooks → your endpoint)
CLERK_WEBHOOK_SECRET=whsec_paste_your_signing_secret_here

# Clerk FAPI Proxy — routes Clerk frontend-API calls through your domain.
# Must match the CLERK_PROXY_PATH constant in api-server (/api/__clerk).
# Format: https://<your-domain>/api/__clerk
VITE_CLERK_PROXY_URL=https://myorder.fun/api/__clerk

# ── Session ─────────────────────────────────────────────────
# Long random string — run: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ── OpenAI (AI Concierge) ───────────────────────────────────
OPENAI_API_KEY=paste_your_openai_api_key_here

# ── Stripe (Payments) ───────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=paste_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=paste_your_stripe_publishable_key_here

# ── Twilio (SMS Notifications) ──────────────────────────────
TWILIO_ACCOUNT_SID=paste_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=paste_your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Phone number to receive admin alerts
ADMIN_ALERT_PHONE=+1XXXXXXXXXX

# ── Uber Direct / Uber Courier ───────────────────────────────
# Existing mixed-case names are also accepted by docker-compose.
UBER_CLIENT_ID=paste_your_uber_client_id_here
UBER_CUSTOMER_ID=paste_your_uber_customer_id_here
UBER_CLIENT_SECRET=paste_your_uber_client_secret_here
# Used as the merchant pickup address for quote creation. If blank, the first
# saved CSR shift location address is used.
UBER_PICKUP_ADDRESS=
UBER_PICKUP_ACTION=pick_pack_pay

# ── Thermal Print Bridge ─────────────────────────────────────
# Shared secret between the API server and the print bridge.
# Run: openssl rand -base64 32  and paste the same value in both .env files.
PRINT_BRIDGE_API_KEY=paste_a_long_random_secret_here
# Mac Studio / Tailscale bridge example:
# PRINT_BRIDGE_URL=http://100.x.y.z:3100
# PRINT_SERVER_HOST=100.x.y.z
RECEIPT_PRINT_ENABLED=false
RECEIPT_PRINTER_NAME=receipt
LABEL_PRINT_ENABLED=false
LABEL_PRINTER_NAME=Label_Themal_Printer

# ── WooCommerce (Lucifer Cruz menu tab — optional) ──────────
# Set this URL to activate the LC WooCommerce store tab
VITE_WOOCOMMERCE_URL=

# ── Internal ────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# LUXit phone emergency forwarding
CALL_FORWARD_TO=+1XXXXXXXXXX
TWILIO_CALLER_ID=+1TWILIONUMBER
PHONE_ALWAYS_FORWARD=true
