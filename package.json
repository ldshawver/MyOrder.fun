{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "lint:ratchet": "pnpm --filter @workspace/scripts lint:ratchet",
    "test": "pnpm --filter @workspace/api-server test"
  },
  "private": true,
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/pro-components": "^2.8.10",
    "@plasmicapp/react-web": "^1.0.9",
    "@plasmicpkgs/antd5": "^0.0.346",
    "@plasmicpkgs/plasmic-basic-components": "^0.0.275",
    "@plasmicpkgs/plasmic-rich-components": "^1.0.252",
    "@plasmicpkgs/react-chartjs-2": "^1.0.156",
    "chart.js": "^4.5.1",
    "react-chartjs-2": "^5.3.1"
  }
}
