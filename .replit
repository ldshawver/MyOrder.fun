modules = ["nodejs-24", "python-3.11", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/platform"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

  [[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Platform"

  [[workflows.workflow]]
  name = "lint"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "pnpm lint"

  [workflows.workflow.metadata]
  isValidation = true

[[workflows.workflow]]
name = "Start Platform"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5173 BASE_PATH=/ node artifacts/platform/dev-server.mjs"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "webview"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
  channel = "stable-25_05"

  [userenv]

  [userenv.shared]
  SMTP_FROM = "no-reply@alavont.com"
  SMTP_USER = "luke@adiken.com"
  SMTP_HOST = "smtp.office365.com"
  SMTP_PORT = "587"
  SMTP_TLS = "true"
  RECEIPT_PRINTER_URI = "ipp://100.83.99.2:631/printers/receipt"
  RECEIPT_PRINTER_NAME = "receipt"
  PRINT_SERVER_HOST = "100.83.99.2"
  PRINT_SERVER_PORT = "631"

[[ports]]
localPort = 8080
externalPort = 80
  